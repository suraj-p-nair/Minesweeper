<Page x:Class="MineSweeper.Pages.StartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MineSweeper.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="400" d:DesignWidth="400"
      HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch"
      Title="StartPage">

    <Grid Background="LightGray">
        <Grid.RowDefinitions>
            <RowDefinition Height=" 100"/>
            <RowDefinition Height=" 100"/>
            <RowDefinition Height=" 100"/>
            <RowDefinition Height=" 100"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Minesweeper" 
               FontSize="30" 
               HorizontalAlignment="Center" 
               VerticalAlignment="Center" 
               Grid.Row="0"/>
        <Button Content="Start Game" Grid.Row="1" FontSize="20" Width="200" Click="StartGame"></Button>
        <Button Content="Exit" Grid.Row="2"  FontSize="20" Width="200" Click="Exit"></Button>
        <TextBlock Text="© 2025 My Game" 
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Grid.Row="3"/>
    </Grid>
</Page>
