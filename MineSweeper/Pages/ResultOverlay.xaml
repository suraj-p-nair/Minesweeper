<UserControl x:Class="MineSweeper.Pages.ResultOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#AA000000">
        <!-- semi-transparent backdrop -->
        <Border Background="White" Padding="20" CornerRadius="10" Width="300" Height="200">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" Text="Game Over"
                           FontSize="24" FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="CurrentTimeText" Text="Current Time: 0s"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="BestTimeText" Text="Best Time: 0s"
                           HorizontalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" Margin="0,20,0,0"
                            HorizontalAlignment="Center">
                    <Button Content="Close" Width="100" Margin="5" Click="Close_Click"/>
                    <Button Content="Main Menu" Width="100" Margin="5" Click="MainMenu_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
